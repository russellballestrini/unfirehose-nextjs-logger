digraph dataflow {
  rankdir=LR
  bgcolor="#1a1a2e"
  fontcolor="#e0e0e0"
  node [shape=box style="filled,rounded" fontname="monospace" fontsize=9 color="#333355" fontcolor="#e0e0e0"]
  edge [color="#666688" fontcolor="#999999" fontsize=8]

  // Sources
  subgraph cluster_source {
    label="Data Sources"
    style=dashed
    color="#444466"
    fontcolor="#999999"

    claude_code [label="Claude Code CLI\nagent sessions" fillcolor="#3a3a1a" shape=hexagon]
    ssh_nodes [label="SSH Mesh Nodes\ncammy, blanka, ..." fillcolor="#3a3a1a" shape=hexagon]
    mesh_llm [label="Mesh LLM\nQwen 3 Coder\nHermes 3" fillcolor="#3a3a1a" shape=hexagon]
  }

  // Raw files
  subgraph cluster_files {
    label="~/.claude/projects/"
    style=dashed
    color="#444466"
    fontcolor="#999999"

    jsonl_files [label="*.jsonl\nper session\nappend-only" fillcolor="#2a2a4a"]
    index_files [label="sessions-index.json\nper project\nClaude manages" fillcolor="#2a2a4a"]
    cred_files [label=".credentials.json\nOAuth token" fillcolor="#2a2a4a"]
  }

  // Two read paths
  subgraph cluster_direct {
    label="Direct Read Path\n(real-time, no DB)"
    style=dashed
    color="#336633"
    fontcolor="#669966"

    stream_jsonl [label="streamJsonl()\nasync generator\ntype filter" fillcolor="#1a3a2a"]
    fs_watch [label="fs.watch()\n+ 2s poll fallback" fillcolor="#1a3a2a"]
    byte_tail [label="readNewLines()\nfromByte offset" fillcolor="#1a3a2a"]
  }

  subgraph cluster_ingest_path {
    label="Ingestion Path — @unturf/unfirehose (npm)\n(batch, normalized)"
    style=dashed
    color="#333366"
    fontcolor="#666699"

    ingest [label="ingestAll()\nbyte offset tracking\n500-line batch txn" fillcolor="#1a2a3a"]
    normalize [label="normalize\nmessages → blocks\nusage → minutes" fillcolor="#1a2a3a"]
    dedup [label="INSERT OR IGNORE\nuuid dedup index" fillcolor="#1a2a3a"]
  }

  // Storage
  sqlite [label="SQLite\nWAL mode\nmesh_snapshots\nsettings" fillcolor="#2a2a4a" shape=cylinder]

  // Browser vault
  subgraph cluster_vault {
    label="Browser Vault (Zero-Knowledge)"
    style=dashed
    color="#663333"
    fontcolor="#cc6666"

    vault_store [label="localStorage\nAES-GCM encrypted\nPBKDF2 600k iter" fillcolor="#3a1a1a" shape=cylinder]
    vault_gate [label="VaultGate\npassword on first open\nsession auto-restore" fillcolor="#3a2a2a"]
    vault_keys [label="BYOK API Keys\nper-provider\nnever on server" fillcolor="#3a2a2a"]
  }

  // Outputs
  subgraph cluster_output {
    label="Consumer Paths"
    style=dashed
    color="#444466"
    fontcolor="#999999"

    sse [label="SSE\n/api/live\nreal-time events" fillcolor="#3a2a1a"]
    rest [label="REST JSON\n/api/*\nSWR cached" fillcolor="#1a2a3a"]
    thinking_scan [label="Thinking Scan\ncross-project\nJSONL direct" fillcolor="#2a1a3a"]
  }

  // Todo extraction
  subgraph cluster_todo {
    label="Todo Extraction"
    style=dashed
    color="#336666"
    fontcolor="#669999"

    tool_use_scan [label="content_blocks\ntool_use filter\nTaskCreate/TaskUpdate\nTodoWrite" fillcolor="#1a3a3a"]
    todo_normalize [label="normalize todo\nstatus + metadata" fillcolor="#1a3a3a"]
  }

  // LLM commit flow
  subgraph cluster_llm {
    label="LLM Commit Messages"
    style=dashed
    color="#336633"
    fontcolor="#669966"

    git_suggest [label="/api/projects/[p]/git/suggest\nPOST — generate message" fillcolor="#1a3a2a"]
    resolve_provider [label="resolveProvider()\n1. vault BYOK\n2. Claude Max OAuth\n3. Qwen mesh\n4. Hermes mesh" fillcolor="#2a3a2a"]
  }

  // Mesh monitoring
  subgraph cluster_mesh {
    label="Mesh Monitoring"
    style=dashed
    color="#333366"
    fontcolor="#666699"

    mesh_probe [label="SSH probes\nCPU, RAM, GPU\npower (RAPL + nvidia-smi)" fillcolor="#1a2a3a"]
    mesh_snapshot [label="mesh_snapshots\ntime-series INSERT\nper-node" fillcolor="#1a2a3a"]
  }

  // Manual todo injection
  todo_ui [label="Todo UI\nform input" fillcolor="#1a3a2a"]
  todo_api [label="POST /api/todos\nvalidate + insert" fillcolor="#1a3a2a"]

  // Attachment upload
  attach_api [label="/api/todos/attachments\nPOST/GET/DELETE" fillcolor="#1a3a3a"]
  attach_store [label="~/.unfirehose/attachments/\nSHA-256 content-addressed" fillcolor="#2a2a4a" shape=folder]

  // Storage
  todos_table [label="todos table\n+ todo_events" fillcolor="#1a3a3a" shape=cylinder]
  vis_table [label="project_visibility\ntable" fillcolor="#3a2a3a" shape=cylinder]

  // Browser
  browser [label="React SPA\nVaultShell wrapper\nuseSWR + EventSource" fillcolor="#2a1a3a" shape=component]

  // Flow
  claude_code -> jsonl_files [label="append\nper turn"]
  claude_code -> index_files [label="update\nmetadata"]

  // Direct path
  jsonl_files -> stream_jsonl [label="async\niterate"]
  jsonl_files -> fs_watch [label="watch\nchanges"]
  jsonl_files -> byte_tail [label="tail\nnew bytes"]
  stream_jsonl -> thinking_scan
  stream_jsonl -> rest [label="session\nreplay"]
  fs_watch -> byte_tail [label="trigger"]
  byte_tail -> sse [label="new\nentries"]

  // Ingest path
  jsonl_files -> ingest [label="createReadStream\nfrom offset"]
  index_files -> ingest [label="session\nmeta"]
  ingest -> normalize -> dedup -> sqlite

  // DB to API
  sqlite -> rest [label="prepared\nstatements"]

  // Todo extraction flow
  dedup -> tool_use_scan [label="content_blocks\nwith tool_use"]
  tool_use_scan -> todo_normalize -> todos_table

  // Manual todo injection flow
  browser -> todo_ui [label="user\ninput"]
  todo_ui -> todo_api -> todos_table

  // Attachment upload flow
  browser -> attach_api [label="drag-drop\nupload"]
  attach_api -> attach_store [label="SHA-256\nwrite"]
  attach_api -> todos_table [label="todo_attachments\nINSERT"]

  // Vault flow
  browser -> vault_gate [label="password\nprompt"]
  vault_gate -> vault_store [label="PBKDF2\nderive key"]
  vault_store -> vault_keys [label="AES-GCM\ndecrypt"]
  vault_keys -> git_suggest [label="x-vault-api-key\nheader (per-request)" color="#663333"]

  // LLM flow
  cred_files -> resolve_provider [label="OAuth\ntoken" style=dashed]
  vault_keys -> resolve_provider [label="BYOK\nkey" style=dashed color="#663333"]
  mesh_llm -> resolve_provider [label="fallback\nno key needed" style=dashed]
  resolve_provider -> git_suggest

  // Mesh flow
  ssh_nodes -> mesh_probe [label="SSH\ncommands"]
  mesh_probe -> mesh_snapshot -> sqlite

  // New tables -> API -> browser
  todos_table -> rest [label="GET /api/todos"]
  vis_table -> rest [label="GET /api/scrobble"]

  // To browser
  sse -> browser [label="EventSource"]
  rest -> browser [label="fetch/SWR"]
  thinking_scan -> browser [label="fetch/SWR"]
}
