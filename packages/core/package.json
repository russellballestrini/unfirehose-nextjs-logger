{
  "name": "@unturf/unfirehose",
  "version": "1.0.5",
  "description": "Core data layer for unfirehose — Claude Code session ingestion, SQLite schema, types, PII detection, and formatters",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/russellballestrini/unfirehose.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/russellballestrini/unfirehose#readme",
  "keywords": [
    "claude-code",
    "jsonl",
    "session-logs",
    "sqlite",
    "ingestion",
    "observability",
    "unturf",
    "permacomputer"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "*.ts",
    "db/*.ts",
    "!**/*.test.ts",
    "!vitest.config.ts"
  ],
  "exports": {
    "./db/schema": "./db/schema.ts",
    "./db/ingest": "./db/ingest.ts",
    "./db/watcher": "./db/watcher.ts",
    "./db/control": "./db/control.ts",
    "./db/api-keys": "./db/api-keys.ts",
    "./db/tenant": "./db/tenant.ts",
    "./db/triage": "./db/triage.ts",
    "./claude-paths": "./claude-paths.ts",
    "./claude-paths-client": "./claude-paths-client.ts",
    "./fetch-paths": "./fetch-paths.ts",
    "./uncloseai-paths": "./uncloseai-paths.ts",
    "./uncloseai-adapter": "./uncloseai-adapter.ts",
    "./jsonl-reader": "./jsonl-reader.ts",
    "./format": "./format.ts",
    "./types": "./types.ts",
    "./pii": "./pii.ts",
    "./session-name": "./session-name.ts",
    "./uuidv7": "./uuidv7.ts",
    "./mesh": "./mesh.ts",
    "./tiers": "./tiers.ts",
    "./auth": "./auth.ts",
    "./rate-limit": "./rate-limit.ts",
    "./apmonitor-adapter": "./apmonitor-adapter.ts",
    "./training": "./training.ts",
    "./project-name": "./project-name.ts",
    "./agnt-paths": "./agnt-paths.ts",
    "./claude-code-adapter": "./claude-code-adapter.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@unturf/unfirehose-config": "*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
